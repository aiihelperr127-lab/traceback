# 1) Apache often does NOT pass Authorization to PHP — backend then gets no Bearer token → 401.
#    This line exposes it as $_SERVER['HTTP_AUTHORIZATION'] for api-proxy.php.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{HTTP:Authorization} ^(.+)$
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
</IfModule>

# 2) API → PHP proxy (keep $BACKEND in api-proxy.php)
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_URI} ^/api/
  RewriteRule ^api/(.*)$ api-proxy.php?__api_path=$1 [QSA,L,B]
</IfModule>

# 3) SPA
<IfModule mod_rewrite.c>
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
